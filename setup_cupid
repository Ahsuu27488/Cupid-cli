#!/usr/bin/env bash
################################################################################
# Cupid Universal Installer
# 💝 A beautiful, one-command setup for Cupid AI companion
#
# Supports: Termux (Android), Linux, macOS
# Usage: bash setup_cupid [--remote] [--help]
#   --remote    Install directly from GitHub URL (curl | bash)
#   --help      Show this help message
#
# Made by Ahsan for Ashu 💕
################################################################################

set -euo pipefail  # Exit on errors, undefined vars, pipe failures

# Colors for beautiful output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
RESET='\033[0m'
BOLD='\033[1m'

# Configuration
# Determine install directory - respects $INSTALL_DIR if set
if [[ -n "${INSTALL_DIR:-}" ]]; then
    # User specified via env var, use it
    :
elif git rev-parse --is-inside-work-tree &>/dev/null && [[ -f "pyproject.toml" ]]; then
    # Running from inside Cupid repo, install here
    INSTALL_DIR="$(pwd)"
else
    # Default to $HOME/Cupid
    INSTALL_DIR="$HOME/Cupid"
fi

VENV_DIR="${VENV_DIR:-$INSTALL_DIR/.venv}"
REPO_URL="https://github.com/Ahsuu27488/Cupid.git"
BIN_DIR="${BIN_DIR:-$HOME/.local/bin}"
TERMUX_BIN="/data/data/com.termux/files/usr/bin"

# Progress bar variables
TOTAL_STEPS=9
CURRENT_STEP=0

# Time estimates per step (in seconds) for display
# Index 0 = step 1, etc.
STEP_ESTIMATES=(2 10 5 30 25 90 10 5 5)

################################################################################
# Helper Functions
################################################################################

get_system_python() {
    # Find a system Python interpreter (not from a virtual environment)
    local candidates=()

    # Add common paths based on platform
    case "$PLATFORM" in
        termux) candidates+=("/data/data/com.termux/files/usr/bin/python3") ;;
        macos)  candidates+=("/opt/homebrew/bin/python3" "/usr/local/bin/python3" "/usr/bin/python3") ;;
        linux)  candidates+=("/usr/bin/python3" "/usr/local/bin/python3") ;;
    esac

    # Check each candidate
    for py in "${candidates[@]}"; do
        if [[ -x "$py" ]]; then
            echo "$py"
            return 0
        fi
    done

    # Fall back to python3 in PATH (might be venv, but we'll try)
    command -v python3
}

log_info() {
    echo -e "${CYAN}[INFO]${RESET} $1"
}

log_success() {
    echo -e "${GREEN}[✓]${RESET} $1"
}

log_warning() {
    echo -e "${YELLOW}[!]${RESET} $1"
}

log_error() {
    echo -e "${RED}[✗]${RESET} $1" >&2
}

log_step() {
    CURRENT_STEP=$((CURRENT_STEP + 1))
    local msg="$1"
    local percent=$((CURRENT_STEP * 100 / TOTAL_STEPS))
    local est="${STEP_ESTIMATES[CURRENT_STEP-1]:-?}"

    # Draw progress bar
    printf "\r"
    progress_bar "$percent"
    printf " ${BOLD}%3d%%${RESET} %s" "$percent" "$msg"
    if [[ "$est" != "?" ]]; then
        printf " ${CYAN}(~%ds)${RESET}" "$est"
    fi
    printf "\n"
}

progress_bar() {
    local percent=$1
    local width=40
    local filled=$((percent * width / 100))
    local empty=$((width - filled))

    printf "\r${CYAN}["
    printf "%0.s█" $(seq 1 $filled)
    printf "%0.s " $(seq 1 $empty)
    printf "]${RESET} ${BOLD}%3d%%${RESET}" "$percent"
}

spinner() {
    local pid=$1
    local delay=0.1
    local spinstr='|/-\'
    while kill -0 "$pid" 2>/dev/null; do
        local temp=${spinstr#?}
        printf " [%c]  " "$spinstr"
        spinstr=$temp${spinstr%"$temp"}
        sleep $delay
        printf "\b\b\b\b\b\b"
    done
    printf "    \b\b\b\b"
}

estimate_time() {
    # Rough time estimates for each step (in seconds)
    case "$1" in
        "detect") echo "1-2" ;;
        "clone") echo "5-15" ;;
        "venv") echo "10-30" ;;
        "deps") echo "30-90" ;;
        "config") echo "1-2" ;;
        "symlink") echo "1-2" ;;
        *) echo "2-5" ;;
    esac
}

