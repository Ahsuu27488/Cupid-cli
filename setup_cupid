################################################################################
# Detection Functions
################################################################################

detect_platform() {
    log_step "Detecting your platform..."

    # Check if running inside active venv and warn
    if [[ -n "${VIRTUAL_ENV:-}" ]]; then
        log_warning "You are inside a virtual environment."
        log_warning "For cleanest install, we recommend deactivating first."
        read -p "  Continue anyway? (y/N): " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            log_info "Please run: deactivate"
            log_info "Then try again."
            exit 1
        fi
    fi

    if [[ -d /data/data/com.termux ]]; then
        PLATFORM="termux"
        log_success "Detected: Termux (Android) 📱"
    elif [[ "$(uname)" == "Darwin" ]]; then
        PLATFORM="macos"
        log_success "Detected: macOS 🍎"
    else
        PLATFORM="linux"
        log_success "Detected: Linux 🐧"
    fi

    echo "platform=$PLATFORM" > /tmp/cupid_install.conf
}

check_dependencies() {
    log_step "Checking dependencies..."

    local missing=()

    # Check Python
    if ! command -v python3 &>/dev/null; then
        missing+=("python3")
    fi

    # Check git
    if ! command -v git &>/dev/null; then
        missing+=("git")
    fi

    if [[ ${#missing[@]} -gt 0 ]]; then
        log_warning "Missing: ${missing[*]}"

        if [[ "$PLATFORM" == "termux" ]]; then
            log_info "Installing via Termux package manager..."
            pkg update -y
            pkg install -y python git
        else
            log_error "Please install missing dependencies:"
            for dep in "${missing[@]}"; do
                echo "  - $dep"
            done
            exit 1
        fi
    fi

    log_success "All dependencies available!"
}

setup_python() {
    log_step "Setting up Python environment..."

    if [[ "$PLATFORM" == "termux" ]]; then
        log_info "Configuring Termux environment..."
        # Termux-specific setup
        termux-setup-storage 2>/dev/null || true
    fi

    # Get system Python (not from venv)
    local PYTHON
    PYTHON="$(get_system_python)"

    if [[ -z "$PYTHON" ]]; then
        log_error "Python 3 not found! Please install Python 3.11+ and try again."
        exit 1
    fi

    log_info "Found Python: $($PYTHON -V 2>&1)"

    # Check pip availability
    if ! $PYTHON -m pip --version &>/dev/null; then
        log_warning "pip not available with this Python..."
        if [[ "$PLATFORM" == "termux" ]]; then
            log_info "Installing pip via Termux..."
            pkg install -y python
        else
            log_error "Please ensure python3-pip is installed."
            log_info "On Ubuntu/Debian: sudo apt-get install python3-pip"
            log_info "On macOS: brew install python"
            exit 1
        fi
    fi

    log_success "Python environment ready!"
}

clone_or_update() {
    log_step "Setting up Cupid source code..."

    # Check if INSTALL_DIR is a git repository
    if git -C "$INSTALL_DIR" rev-parse --is-inside-work-tree &>/dev/null; then
        # Already a git repo
        if [[ "$INSTALL_DIR" == "$(pwd)" ]]; then
            log_info "Using current repository (in-place setup) ✓"
        else
            log_info "Found existing repository at $INSTALL_DIR"
            read -p "  Pull latest changes? (y/N): " -n 1 -r
            echo
            if [[ $REPLY =~ ^[Yy]$ ]]; then
                (cd "$INSTALL_DIR" && git pull --rebase)
                log_success "Updated repository ✓"
            else
                log_info "Using existing repository (no update)"
            fi
        fi
    else
        # INSTALL_DIR is not a git repo
        if [[ -e "$INSTALL_DIR" ]] && [[ ! -d "$INSTALL_DIR" ]]; then
            log_error "$INSTALL_DIR exists but is not a directory"
            exit 1
        fi

        if [[ -d "$INSTALL_DIR" ]] && [[ "$(ls -A "$INSTALL_DIR" 2>/dev/null)" ]]; then
            log_warning "$INSTALL_DIR exists and is not empty (not a git repo)"
            read -p "  Remove and clone fresh? (y/N): " -n 1 -r
            echo
            if [[ $REPLY =~ ^[Yy]$ ]]; then
                rm -rf "$INSTALL_DIR"
                log_info "Cloning Cupid repository..."
                git clone "$REPO_URL" "$INSTALL_DIR"
                log_success "Cloned to $INSTALL_DIR ✓"
            else
                log_error "Cannot proceed - $INSTALL_DIR is not a Cupid repository"
                exit 1
            fi
        else
            # Empty or non-existent directory - clone
            log_info "Cloning repository..."
            if [[ -d "$INSTALL_DIR" ]]; then
                # Empty existing dir, clone into it
                git clone "$REPO_URL" "$INSTALL_DIR"
            else
                # Parent exists, clone creates dir
                git clone "$REPO_URL" "$INSTALL_DIR"
            fi
            log_success "Cloned to $INSTALL_DIR ✓"
        fi
    fi
}

create_venv() {
    log_step "Creating virtual environment..."

    if [[ -d "$VENV_DIR" ]]; then
        log_warning "Virtual environment already exists"
        read -p "  Recreate? (y/N): " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            rm -rf "$VENV_DIR"
        else
            log_info "Using existing venv"
            return
        fi
    fi

    log_info "Building virtual environment..."
    local PYTHON
    PYTHON="$(get_system_python)"
    "$PYTHON" -m venv "$VENV_DIR"

    log_success "Virtual environment created!"
}

install_dependencies() {
    log_step "Installing dependencies..."

    cd "$INSTALL_DIR"

    # Use venv Python directly (no activation needed)
    local PYTHON="$VENV_DIR/bin/python"
    local PIP="$VENV_DIR/bin/pip"

    # Ensure pip is available in venv
    if [[ ! -x "$PIP" ]]; then
        log_info "Bootstrapping pip in virtual environment..."
        curl -sS https://bootstrap.pypa.io/get-pip.py | "$PYTHON"
    fi

    # Upgrade pip
    log_info "Updating pip (in venv)..."
    "$PIP" install --upgrade pip -q

    # Install from requirements.txt
    log_info "Downloading and installing packages..."
    "$PIP" install -r requirements.txt -q

    log_success "All dependencies installed!"
}

configure_api_key() {
    log_step "Configuring OpenAI API key..."

    ENV_FILE="$INSTALL_DIR/.env"

    if [[ -f "$ENV_FILE" ]]; then
        log_warning ".env file already exists"
        read -p "  Overwrite? (y/N): " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            log_info "Keeping existing .env file"
            return
        fi
    fi

    echo "# Cupid Configuration" > "$ENV_FILE"
    echo "# Generated by setup_cupid on $(date)" >> "$ENV_FILE"
    echo "" >> "$ENV_FILE"

    # Prompt for API key
    echo -e "${YELLOW}You need an OpenAI API key for Cupid to work.${RESET}"
    echo -e "${CYAN}Get yours at: https://platform.openai.com/api-keys${RESET}"
    echo
    read -p "Enter your OpenAI API key: " -r API_KEY
    echo

    if [[ -z "$API_KEY" ]]; then
        log_error "API key is required!"
        exit 1
    fi

    echo "OPENAI_API_KEY=$API_KEY" >> "$ENV_FILE"
    echo "MODEL=gpt-4o-mini" >> "$ENV_FILE"
    echo "MAX_CONTEXT_TOKENS=2000" >> "$ENV_FILE"
    echo "SUMMARIZATION_THRESHOLD=1500" >> "$ENV_FILE"
    echo "MAX_RESPONSE_TOKENS=150" >> "$ENV_FILE"
    echo "MEMORY_DB=$INSTALL_DIR/memory.db" >> "$ENV_FILE"
    echo "DEFAULT_MOOD=flirty" >> "$ENV_FILE"

    # Secure the .env file
    chmod 600 "$ENV_FILE"

    log_success "Configuration saved to .env"
}

setup_symlink() {
    log_step "Creating 'cupid' command..."

    # Determine where to create symlink
    if [[ "$PLATFORM" == "termux" ]]; then
        SYMLINK_DIR="/data/data/com.termux/files/usr/bin"
    else
        SYMLINK_DIR="$HOME/.local/bin"
        # Create bin directory if it doesn't exist
        mkdir -p "$SYMLINK_DIR"
    fi

    SYMLINK_PATH="$SYMLINK_DIR/cupid"

    # Remove old symlink if exists
    if [[ -L "$SYMLINK_PATH" ]]; then
        rm "$SYMLINK_PATH"
    fi

    # Create launcher script directly (no need to activate venv)
    LAUNCHER="$SYMLINK_DIR/cupid"
    cat > "$LAUNCHER" << LAUNCHER_EOF
#!/usr/bin/env bash
# Cupid launcher - starts the AI companion
# Installed by setup_cupid

cd "$INSTALL_DIR" || exit 1
exec "$VENV_DIR/bin/python" -m cupid.main "\$@"
LAUNCHER_EOF

    # Make launcher executable
    chmod +x "$LAUNCHER"

    # Verify it's in PATH
    if [[ ":$PATH:" != *":$SYMLINK_DIR:"* ]]; then
        log_warning "$SYMLINK_DIR is not in your PATH"
        log_info "Add it to your shell configuration? (recommended)"

        # Detect shell rc file
        local rc_file=""
        if [[ -f "$HOME/.bashrc" ]]; then
            rc_file="$HOME/.bashrc"
        elif [[ -f "$HOME/.zshrc" ]]; then
            rc_file="$HOME/.zshrc"
        elif [[ -f "$HOME/.profile" ]]; then
            rc_file="$HOME/.profile"
        fi

        if [[ -n "$rc_file" ]]; then
            read -p "  Add to $rc_file? (y/N): " -n 1 -r
            echo
            if [[ $REPLY =~ ^[Yy]$ ]]; then
                echo "" >> "$rc_file"
                echo "# Cupid command" >> "$rc_file"
                echo "export PATH=\"$SYMLINK_DIR:\$PATH\"" >> "$rc_file"
                log_success "Added to $rc_file"
                log_info "Restart terminal or run: source $rc_file"
            else
                log_info "You can add it manually later."
            fi
        else
            log_info "Add this to your shell config:"
            echo "  export PATH=\"$SYMLINK_DIR:\$PATH\""
        fi
    else
        log_success "Cupid is ready in your PATH!"
    fi
}

test_installation() {
    log_step "Testing installation..."

    cd "$INSTALL_DIR"

    # Use venv Python directly
    local PYTHON="$VENV_DIR/bin/python"

    # Quick import test
    if "$PYTHON" -c "import cupid; print('OK')" 2>/dev/null; then
        log_success "Python modules verified"
    else
        log_error "Python import failed"
        return 1
    fi

    # Test configuration
    if [[ -f ".env" ]]; then
        log_success "Configuration found"
    else
        log_error ".env file missing"
        return 1
    fi

    return 0
}

