################################################################################
# Main Installation Flow
################################################################################

main() {
    # Parse arguments
    REMOTE_INSTALL=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --remote|-r)
                REMOTE_INSTALL=true
                shift
                ;;
            --help|-h)
                show_help
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                show_help
                exit 1
                ;;
        esac
    done

    # Show banner
    show_banner

    # Confirm installation
    echo -e "${YELLOW}This will install Cupid on your system.${RESET}"
    echo -e "Install location: ${CYAN}$INSTALL_DIR${RESET}"
    echo
    read -p "Continue? (Y/n): " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Nn]$ ]]; then
        log_info "Installation cancelled"
        exit 0
    fi

    # Start installation
    TOTAL_STEPS=9

    detect_platform
    check_dependencies
    setup_python
    clone_or_update
    create_venv
    install_dependencies
    configure_api_key
    setup_symlink

    if test_installation; then
        show_summary
        exit 0
    else
        log_error "Installation test failed"
        exit 1
    fi
}

# Run main function only if script is executed (not sourced)
if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    main "$@"
fi
