# OpenAI API Configuration
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Model to use (optional, defaults to gpt-4o-mini)
# Options: gpt-4o, gpt-4o-mini, gpt-4-turbo, etc.
MODEL=gpt-4o-mini

# Memory Settings (optional)
# Max tokens for context window (default: 2000)
# MAX_CONTEXT_TOKENS=2000

# Summarization threshold (default: 1500)
# When memory exceeds this, old messages get summarized
# SUMMARIZATION_THRESHOLD=1500

# Database path (default: memory.db)
# MEMORY_DB=memory.db

# Personality (optional)
# DEFAULT_MOOD=flirty

# Response length (optional, default 150 tokens)
# MAX_RESPONSE_TOKENS=150
